          <AuxValues>
            <AuxValue name="JavaCodeGenerator_ListenersCodePost" type="java.lang.String" value="txtUsername.addKeyListener( new KeyAdapter() {public void keyTyped(KeyEvent e) {&#xa;    char c = e.getKeyChar();&#xa;    if (((c &lt; &apos;0&apos;) || (c &gt; &apos;9&apos;)) &amp;&amp; ((c &lt; &apos;A&apos;) || (c &gt; &apos;Z&apos;)) &amp;&amp; ((c &lt; &apos;a&apos;) || (c &gt; &apos;z&apos;)) &amp;&amp; (c != KeyEvent.VK_BACK_SPACE)) { e.consume();}&#xa;    if(txtUsername.getText().matches(&quot;[a-zA-Z0-9]{1,}&quot;)){ lblWUN.setVisible(false);}&#xa;    else{lblWUN.setVisible(true);}&#xa;}});"/>
          </AuxValues>
        </Component>
